<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <!-- 安全头 -->
        <httpProtocol>
            <customHeaders>
                <add name="X-Content-Type-Options" value="nosniff" />
                <add name="X-Frame-Options" value="DENY" />
                <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
                <!-- CSP 按需调整，避免阻止正常功能 (Twemoji CDN、运势 API 等)
                <add name="Content-Security-Policy" value="default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; media-src 'self'; connect-src 'self' https://v2.xxapi.cn" />
                -->
            </customHeaders>
        </httpProtocol>

        <!-- 启用静态内容压缩 -->
        <urlCompression doStaticCompression="true" doDynamicCompression="true" />

        <!-- 禁止目录浏览 -->
        <directoryBrowse enabled="false" />

        <!-- 默认不缓存（HTML 每次都验证最新版） -->
        <staticContent>
            <clientCache cacheControlMode="DisableCache" />
        </staticContent>
    </system.webServer>

    <!-- CSS/JS: 缓存 1 天 -->
    <location path="css">
        <system.webServer>
            <staticContent>
                <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="1.00:00:00" />
            </staticContent>
        </system.webServer>
    </location>
    <location path="js">
        <system.webServer>
            <staticContent>
                <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="1.00:00:00" />
            </staticContent>
        </system.webServer>
    </location>

    <!-- assets 资源: 缓存 30 天 -->
    <location path="assets">
        <system.webServer>
            <staticContent>
                <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="30.00:00:00" />
            </staticContent>
        </system.webServer>
    </location>

    <!-- 音乐文件缓存 7 天 -->
    <location path="assets/music">
        <system.webServer>
            <staticContent>
                <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="7.00:00:00" />
            </staticContent>
        </system.webServer>
    </location>

    <!-- Live2D 模型缓存 7 天 -->
    <location path="live2d">
        <system.webServer>
            <staticContent>
                <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="7.00:00:00" />
            </staticContent>
        </system.webServer>
    </location>
</configuration>
